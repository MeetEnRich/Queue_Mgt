# FULafia DQMS — Environment Configuration
# Copy this file to .env and fill in values before running.

SECRET_KEY=change-me-to-a-random-secret-key
FLASK_ENV=development
DATABASE_URL=sqlite:///instance/dqms.sqlite3

# Geofencing Boundary Verification
GEOFENCE_ENABLED=False
GEOFENCE_LATITUDE=8.4746
GEOFENCE_LONGITUDE=8.5583
GEOFENCE_RADIUS_METERS=1500.0

